# Makefile for RISC-V CPU simulation

.PHONY: all clean test_sim

all:
	@echo "RISC-V CPU Makefile"
	@echo "Usage:"
	@echo "  make test_sim name=XXX   - Run simulation test XXX"
	@echo "  make clean               - Clean build files"

test_sim:
	@echo "Running simulation test $(name)..."
	@mkdir -p testspace
	@echo "Test simulation not fully implemented yet"

clean:
	rm -rf testspace/*
